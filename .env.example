# GitHub OAuth (primary connection method)
# Set up a GitHub OAuth App at https://github.com/settings/developers
# Callback URL: your deployed URL (or http://localhost:5173 for local dev)
VITE_GITHUB_CLIENT_ID=your_client_id_here
VITE_GITHUB_WORKER_URL=https://your-worker.your-subdomain.workers.dev
# Optional: override the OAuth redirect URI (defaults to window.location.origin)
# VITE_GITHUB_REDIRECT_URI=https://paceboard.dev

# Optional: Personal Access Token override.
# When set, the entire setup screen is skipped and both OAuth and PAT entry are disabled.
# Useful for private/self-hosted deployments where you control the environment.
# Required scopes: repo  (add read:org for organisation repositories)
# Get a token at: https://github.com/settings/tokens/new?scopes=repo&description=Paceboard+Dev+Analytics
# VITE_GITHUB_TOKEN=ghp_your_token_here
